<%
const diffClass = { beginner:'badge-beg', intermediate:'badge-mid', advanced:'badge-adv' };
const userId = user ? user._id.toString() : null;
const liked  = userId && post.likes && post.likes.map ? post.likes.map(String).includes(userId) : (post.isLiked || false);
const saved  = userId && post.saves && post.saves.map ? post.saves.map(String).includes(userId) : (post.isSaved || false);
const lc     = post.likeCount !== undefined ? post.likeCount : (post.likes ? post.likes.length : 0);
%>
<div class="post-card" id="post-<%= post._id %>">
  <!-- Header -->
  <div class="post-card-header">
    <div class="post-avatar" style="background:hsl(<%= (post.author && post.author.username ? post.author.username.charCodeAt(0) * 13 % 360 : 200) %>,55%,50%)">
      <%= post.author && post.author.username ? post.author.username[0].toUpperCase() : '?' %>
    </div>
    <div class="post-meta">
      <span class="post-author"><%= post.author ? post.author.username : 'Unknown' %></span>
      <span class="post-date"><%= new Date(post.createdAt).toLocaleDateString('en-IN',{month:'short',day:'numeric'}) %> · <%= post.readTime %> min read</span>
    </div>
    <span class="diff-badge <%= diffClass[post.difficulty] || 'badge-beg' %>"><%= post.difficulty %></span>
  </div>

  <!-- Title & preview -->
  <a href="/posts/<%= post._id %>" class="post-title-link">
    <h3 class="post-title"><%= post.title %></h3>
  </a>
  <p class="post-preview"><%= (post.body || '').replace(/[#*`]/g,'').substring(0,150) %>…</p>

  <!-- Code snippet -->
  <% if (post.codeSnippet) { %>
  <pre class="post-code-preview"><%= post.codeSnippet.substring(0, 180) %><% if(post.codeSnippet.length > 180) { %>…<% } %></pre>
  <% } %>

  <!-- Tags -->
  <div class="post-tags">
    <% (post.tags || []).slice(0,4).forEach(t => { %>
    <a href="/feed?tags=<%= t %>" class="post-tag">#<%= t %></a>
    <% }) %>
    <span class="post-views"><%= (post.views || 0).toLocaleString() %> views</span>
  </div>

  <!-- Quiz teaser -->
  <% if (post.quiz && post.quiz.length > 0) { %>
  <button class="quiz-teaser" onclick="openQuizTeaser(this, '<%= post._id %>')">
    🧪 Quick quiz — test yourself on this post
  </button>
  <div class="quiz-teaser-box" id="quiz-teaser-<%= post._id %>" style="display:none">
    <p class="qt-q"><%= post.quiz[0].question %></p>
    <div class="qt-opts">
      <% post.quiz[0].options.forEach((opt, i) => { %>
      <button class="qt-opt" data-post="<%= post._id %>" data-q="0" data-idx="<%= i %>" data-correct="<%= post.quiz[0].correctIndex %>">
        <%= opt %>
      </button>
      <% }) %>
    </div>
    <p class="qt-expl" id="expl-<%= post._id %>-0" style="display:none"><%= post.quiz[0].explanation %></p>
  </div>
  <% } %>

  <!-- Action bar -->
  <div class="post-actions">
    <button class="action-btn like-btn <%= liked ? 'liked' : '' %>"
            data-post="<%= post._id %>"
            onclick="toggleLike(this)"
            <%= !user ? 'data-guest="true"' : '' %>>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="<%= liked ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
      <span class="like-count"><%= lc %></span>
    </button>

    <a href="/posts/<%= post._id %>#comments" class="action-btn">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
      </svg>
      Comment
    </a>

    <a href="/posts/<%= post._id %>" class="action-btn">ELI5</a>

    <button class="action-btn save-btn <%= saved ? 'saved' : '' %>"
            data-post="<%= post._id %>"
            onclick="toggleSave(this)"
            <%= !user ? 'data-guest="true"' : '' %>>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="<%= saved ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
      </svg>
      <%= saved ? 'Saved' : 'Save' %>
    </button>
  </div>
</div>
