<div class="auth-page">
  <div class="auth-glow"></div>
  <div class="auth-card">
    <a href="/" class="auth-logo">
      <div class="nav-logo-icon">K</div>
      <span class="nav-logo-text">KnowVerse</span>
    </a>
    <h1 class="auth-title">Join KnowVerse</h1>
    <p class="auth-sub">Start your learning journey today — free</p>

    <form action="/auth/register" method="POST" class="auth-form">
      <div class="form-group">
        <label class="form-label">Username</label>
        <input type="text" name="username" class="kv-input" placeholder="your_handle" minlength="3" required/>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="kv-input" placeholder="you@example.com" required/>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="kv-input" placeholder="6+ characters" minlength="6" required/>
      </div>
      <div class="form-group">
        <label class="form-label">Confirm Password</label>
        <input type="password" name="confirm" class="kv-input" placeholder="Repeat password" minlength="6" required/>
      </div>
      <button type="submit" class="btn-primary btn-block">Create Account — Free</button>
    </form>
    <p class="auth-switch">Already a member? <a href="/auth/login">Sign in</a></p>
  </div>
</div>
