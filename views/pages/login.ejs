<div class="auth-page">
  <div class="auth-glow"></div>
  <div class="auth-card">
    <a href="/" class="auth-logo">
      <div class="nav-logo-icon">K</div>
      <span class="nav-logo-text">KnowVerse</span>
    </a>
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-sub">Continue your learning journey</p>

    <form action="/auth/login" method="POST" class="auth-form">
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="kv-input" placeholder="you@example.com" required/>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="kv-input" placeholder="••••••••" required/>
      </div>
      <button type="submit" class="btn-primary btn-block">Sign In</button>
      <button type="button" class="btn-ghost btn-block demo-btn"
        onclick="document.querySelector('[name=email]').value='arjun@test.com';document.querySelector('[name=password]').value='password123'">
        Use demo account ↗
      </button>
    </form>
    <p class="auth-switch">New here? <a href="/auth/register">Create account</a></p>
  </div>
</div>
